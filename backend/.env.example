# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/summrai

# ── Clerk Authentication ───────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=summrai-uploads

# ── HuggingFace ────────────────────────────────────────────────
HF_MODEL_BART=facebook/bart-large-cnn
HF_MODEL_DISTILBART=sshleifer/distilbart-cnn-12-6
HF_MODEL_T5=t5-base
HF_CACHE_DIR=./models_cache

# ── App ────────────────────────────────────────────────────────
DEBUG=false
RATE_LIMIT_PER_MINUTE=20
MAX_TEXT_LENGTH=50000
